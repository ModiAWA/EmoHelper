{
  "schemaVersion": 1,
  "id": "emohelper",
  "version": "${version}",
  "name": "EmoHelper",
  "icon": "Icon.png",
  "description": "A powerful client-side coordinate helper mod for Minecraft. Easily manage, visualize, and share coordinate points in your world.",
  "authors": ["Emo"],
  "contact": {
    "homepage": "https://github.com/ModiAWA/EmoHelper",
    "issues": "https://github.com/ModiAWA/EmoHelper/issues",
    "sources": "https://github.com/ModiAWA/EmoHelper"
  },
  "license": "AGPL-3.0",
  "environment": "client",
  "entrypoints": {
    "fabric-datagen": [
      "com.Emo.emohelper.client.EmohelperDataGenerator"
    ],
    "client": [
      "com.Emo.emohelper.client.EmohelperClient"
    ],
    "main": [
      "com.Emo.emohelper.Emohelper"
    ],
    "modmenu": [
      "com.Emo.emohelper.client.integration.ModMenuIntegration"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  },
  "suggests": {
    "modmenu": "*"
  }
}